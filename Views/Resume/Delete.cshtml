@model ResumeManager.Models.Applicant

@{
    ViewData["Title"] = "Delete";
}

<style>
    /* Custom CSS for enhanced styling */
    .card-header {
        font-size: 24px;
        font-weight: bold;
        color: #fff;
        margin-bottom: 20px;
        background-color: darkgreen; /* Background color green */
        text-align: center;
        border-bottom: 2px solid #ccc; /* Adding a bottom border */
        padding-bottom: 10px; /* Adding some space below the header */
    }

    .table-container {
        border: 1px solid #ccc;
        border-radius: 5px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        padding: 20px;
        margin-bottom: 20px;
    }

    .btn-back,
    .btn-delete {
        margin-top: 20px;
    }
</style>

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-uppercase text-white">
                    <h4>Delete Applicant</h4>
                </div>
                <div class="card-body">
                    <form id="ApplicantForm" enctype="multipart/form-data" asp-action="Delete">
                        <input type="hidden" asp-for="Id" />

                        <div class="table-container">
                            <div class="row">
                                <div class="col-md-6">
                                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                                    <div class="form-group">
                                        <label asp-for="Name" class="control-label">Name:</label>
                                        <input asp-for="Name" class="form-control" readonly />
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Gender" class="control-label">Gender:</label>
                                        <input asp-for="Gender" class="form-control" readonly />
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="Age" class="control-label">Age:</label>
                                        <input asp-for="Age" class="form-control" readonly />
                                    </div>
                                    <!-- Add other input fields as needed -->
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label asp-for="Qualification" class="control-label">Qualification:</label>
                                        <input asp-for="Qualification" class="form-control" readonly />
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="TotalExperience" class="control-label">Total Experience (Years):</label>
                                        <input asp-for="TotalExperience" class="form-control" readonly />
                                    </div>
                                    <div class="form-group">
                                        <label asp-for="PhotoUrl" class="control-label">Photo:</label>
                                        <input asp-for="PhotoUrl" class="form-control" readonly />
                                    </div>
                                </div>
                            </div>
                            <br />
                            <h2 class="section-header bg-success text-white section-header" style="text-align:center; font-size:x-large">Work Experience</h2>
                            <!-- Work Experience table -->
                            <div class="row">
                                <div class="col-md-12">
                                    <table id="ExpTable" class="table table-striped table-sm">
                                        <thead>
                                            <tr>
                                                <th>CompanyName</th>
                                                <th>Designation</th>
                                                <th>YearsWorked</th>
                                            </tr>
                                        </thead>
                                        <tbody class="acc_table">
                                            @foreach (var experience in Model.Experiences)
                                            {
                                                <tr>
                                                    <td>@experience.CompanyName</td>
                                                    <td>@experience.Designation</td>
                                                    <td>@experience.YearsWorked</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>

                        <!-- Buttons -->
                        <div class="row justify-content-center">
                            <div class="col-md-4">
                                <a asp-action="Index" class="btn btn-secondary btn-back">Back</a>
                            </div>
                            <div class="col-md-4">
                                <input type="submit" value="Delete" class="btn btn-danger btn-delete" />
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
